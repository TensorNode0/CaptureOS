# ── Database (Supabase) ──────────────────────────────────────────────────────
# From your Supabase project: Settings → Database → Connection string → URI.
# Use the "Session pooler" URI (port 5432) for long-lived servers.
# Any standard PostgreSQL 15+ URI also works (local dev, Docker, RDS...).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Supabase Auth (GoTrue) ───────────────────────────────────────────────────
# Authentication is owned by Supabase Auth. From your Supabase project:
#   Settings → API → Project URL / anon (public) key / service_role (secret) key
#   Settings → API → JWT Settings → JWT Secret
# The service_role key is used ONLY by backend admin scripts (seed / migrate);
# never expose it to the browser. In the Supabase dashboard also configure SMTP
# and enable email confirmations under Authentication → Providers/Emails.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=change-me
# Test/local-demo only: lets /auth/test-login mint tokens without a live
# Supabase project. MUST be 0 (unset) in production.
AUTH_TEST_MODE=0

# ── Security ─────────────────────────────────────────────────────────────────
# Fernet key that encrypts per-org API keys AND sensitive PII fields at rest —
# generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENC_KEY=change-me

# ── Email delivery ───────────────────────────────────────────────────────────
# Preferred: Resend (resend.com) — create an API key and verify your sending
# domain (captureagent.us) via the DNS records Resend shows you.
RESEND_API_KEY=
EMAIL_FROM=CaptureAgent <noreply@captureagent.us>
# Fallback: any SMTP server (used only if RESEND_API_KEY is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# If neither is set, emails print to the server log and links are surfaced
# in API responses (LOCAL DEVELOPMENT ONLY).

# ── App ──────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000 — Production: https://captureagent.us
FRONTEND_URL=http://localhost:3000

# Demo seed (optional). Set SEED_DEMO=1 to create the demo org + sample data.
SEED_DEMO=0
ADMIN_EMAIL=admin@govcon.io
ADMIN_PASSWORD=Admin#2026
