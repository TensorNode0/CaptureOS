# ── Database (Supabase) ──────────────────────────────────────────────────────
# From your Supabase project: Settings → Database → Connection string → URI.
# Use the "Session pooler" URI (port 5432) for long-lived servers.
# Any standard PostgreSQL 15+ URI also works (local dev, Docker, RDS...).
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── Security ─────────────────────────────────────────────────────────────────
# JWT signing secret — generate with:  openssl rand -hex 32
JWT_SECRET=change-me

# Fernet key that encrypts per-org API keys at rest — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENC_KEY=change-me

# ── Email delivery ───────────────────────────────────────────────────────────
# Preferred: Resend (resend.com) — create an API key and verify your sending
# domain (captureagent.us) via the DNS records Resend shows you.
RESEND_API_KEY=
EMAIL_FROM=CaptureAgent <noreply@captureagent.us>
# Fallback: any SMTP server (used only if RESEND_API_KEY is empty)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# If neither is set, emails print to the server log and links are surfaced
# in API responses (LOCAL DEVELOPMENT ONLY).

# ── App ──────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000 — Production: https://captureagent.us
FRONTEND_URL=http://localhost:3000

# Demo seed (optional). Set SEED_DEMO=1 to create the demo org + sample data.
SEED_DEMO=0
ADMIN_EMAIL=admin@govcon.io
ADMIN_PASSWORD=Admin#2026
